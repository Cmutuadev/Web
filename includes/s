<script>
function toggleGroup(groupId) {
    const content = document.getElementById('group-' + groupId);
    const arrow = document.getElementById('arrow-' + groupId);
    if (content.style.display === 'none' || content.style.display === '') {
        content.style.display = 'block';
        if (arrow) arrow.classList.add('open');
    } else {
        content.style.display = 'none';
        if (arrow) arrow.classList.remove('open');
    }
}
// Initialize all groups closed
['auto-checkers', 'checkers', 'hitters', 'key-based', 'tools', 'preferences', 'custom-apis'].forEach(g => {
    const el = document.getElementById('group-' + g);
    if (el) el.style.display = 'none';
});

function showAddCustomGateModal() {
    document.getElementById('addCustomGateModal').style.display = 'flex';
}
function closeAddCustomGateModal() {
    document.getElementById('addCustomGateModal').style.display = 'none';
}

document.getElementById('addCustomGateForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const name = document.getElementById('customGateName').value.trim();
    const endpoint = document.getElementById('customGateEndpoint').value.trim();
    const cost = parseInt(document.getElementById('customGateCost').value);
    if (!name || !endpoint) {
        Swal.fire('Error', 'Please fill all fields', 'error');
        return;
    }
    try {
        const response = await fetch('/api/add_custom_gate.php', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name, endpoint, cost })
        });
        const data = await response.json();
        if (data.success) {
            Swal.fire('Success', 'Custom API added! Refresh page to see it.', 'success').then(() => {
                location.reload();
            });
        } else {
            Swal.fire('Error', data.error || 'Failed to add', 'error');
        }
    } catch(e) {
        Swal.fire('Error', 'Network error', 'error');
    }
    closeAddCustomGateModal();
});
</script>
